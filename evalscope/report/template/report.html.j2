<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Evaluation Report — {{ models | join(", ") if models else "N/A" }}</title>
  <style>
{% include 'report.css' %}
  </style>
  <!-- Plotly.js via CDN — must load before any inline chart scripts -->
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
</head>
<body>
<div class="container">

  <!-- ── Header ─────────────────────────────────────────── -->
  <header class="report-header">
    <h1>Evaluation Report</h1>
    <ul class="meta-list">
      <li><strong>Model(s):</strong> {{ models | join(", ") if models else "N/A" }}</li>
      <li><strong>Datasets:</strong> {{ datasets | join(", ") if datasets else "N/A" }}</li>
      <li><strong>Generated at:</strong> {{ generated_at }}</li>
      <li><a href="https://github.com/modelscope/evalscope" target="_blank" rel="noopener">EvalScope v{{ evalscope_version }}</a></li>
    </ul>
  </header>

  <!-- ── Overview ───────────────────────────────────────── -->
  <section class="section">
    <h2 class="section-title">Overview</h2>

    {% if summary_rows %}
    <p class="sub-title">Score Summary</p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Dataset</th>
            <th>Model</th>
            <th>Metric</th>
            <th>Score</th>
            <th>Num</th>
          </tr>
        </thead>
        <tbody>
          {% for row in summary_rows %}
          <tr>
            <td>{{ row.dataset }}</td>
            <td>{{ row.model }}</td>
            <td>{{ row.metric }}</td>
            <td class="score-cell">{{ "%.4f" | format(row.score) }}</td>
            <td>{{ row.num }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {% if overview_chart_div %}
    <p class="sub-title">Overall Score Chart</p>
    <div class="chart-card">{{ overview_chart_div | safe }}</div>
    {% endif %}

    {% if sunburst_chart_div %}
    <p class="sub-title">Score Distribution</p>
    <div class="chart-card">{{ sunburst_chart_div | safe }}</div>
    {% endif %}

  </section>

  <hr />

  <!-- ── Results by dataset ─────────────────────────────── -->
  <section class="section">
    <h2 class="section-title">Results by Dataset</h2>

    {% for ds in dataset_sections %}
    <details class="ds-item" {% if loop.first %}open{% endif %}>
      <summary>
        {{ ds.pretty_name }}
        <span class="score-badge">{{ "%.4f" | format(ds.overall_score) }}</span>
      </summary>
      <div class="ds-body">

        {% if ds.description %}
        <details class="desc-toggle">
          <summary>Description</summary>
          <div class="ds-description">{{ ds.description | safe }}</div>
        </details>
        {% endif %}

        {% for msec in ds.model_sections %}

          {% if ds.multi_model %}
          <div class="model-heading">Model: {{ msec.model_name }}</div>
          {% endif %}

          {% if msec.subset_rows %}
          <div class="table-wrap">
            <table>
              <thead>
                <tr><th>Subset</th><th>Metric</th><th>Score</th><th>Num</th></tr>
              </thead>
              <tbody>
                {% for row in msec.subset_rows %}
                <tr>
                  <td>{{ row.subset }}</td>
                  <td>{{ row.metric }}</td>
                  <td class="score-cell">{{ "%.4f" | format(row.score) }}</td>
                  <td>{{ row.num }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% endif %}

          {% if msec.chart_div %}
          <p class="sub-title">{{ ds.pretty_name }} &ndash; Subset Scores{% if ds.multi_model %} ({{ msec.model_name }}){% endif %}</p>
          <div class="chart-card">{{ msec.chart_div | safe }}</div>
          {% endif %}

          {% if msec.analysis_html %}
          <details class="analysis-toggle" open>
            <summary>Analysis</summary>
            <div class="analysis-section">{{ msec.analysis_html | safe }}</div>
          </details>
          {% endif %}

        {% endfor %}

      </div>
    </details>
    {% endfor %}

  </section>

  <!-- ── Footer ─────────────────────────────────────────── -->
  <footer class="report-footer">
    Generated by
    <a href="https://github.com/modelscope/evalscope" target="_blank" rel="noopener">EvalScope v{{ evalscope_version }}</a>
  </footer>

</div>

<!-- Trigger Plotly resize when a closed accordion is opened, ensuring correct chart sizing -->
<script>
  document.querySelectorAll('details.ds-item').forEach(function (el) {
    el.addEventListener('toggle', function () {
      if (el.open) {
        window.dispatchEvent(new Event('resize'));
      }
    });
  });

  // Colour each score cell on a red→yellow→green gradient (0=red, 1=green)
  document.querySelectorAll('td.score-cell').forEach(function (cell) {
    var val = parseFloat(cell.textContent);
    if (isNaN(val)) return;
    var clamped = Math.max(0, Math.min(1, val));
    var hue = Math.round(clamped * 120); // 0 → red, 60 → yellow, 120 → green
    cell.style.color = 'hsl(' + hue + ', 75%, 62%)';
  });
</script>

</body>
</html>
