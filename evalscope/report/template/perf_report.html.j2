<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Performance Report — {{ model }}</title>
  <style>
{% include 'report.css' %}

/* ── Tab group (perf-report specific) ───────────────────────── */
.tab-group { overflow: hidden; }

.tab-nav {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border-md);
  padding: 0 0.75rem;
  overflow-x: auto;
  scrollbar-width: none;
  background: rgba(255,255,255,0.015);
}
.tab-nav::-webkit-scrollbar { display: none; }

.tab-btn {
  padding: 0.65rem 1.15rem;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text-muted);
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  white-space: nowrap;
  transition: color var(--transition), border-color var(--transition);
  margin-bottom: -1px;
  letter-spacing: 0.02em;
}
.tab-btn:hover  { color: var(--text); }
.tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

.tab-pane        { display: none; }
.tab-pane.active { display: block; }

/* ── Per-run summary stat grid ───────────────────────────────── */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 0.55rem 1.5rem;
  padding: 0.9rem 1.25rem 1.1rem;
}
.stat-item { display: flex; flex-direction: column; gap: 0.1rem; }
.stat-key {
  font-size: 0.67rem;
  font-weight: 700;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.07em;
}
.stat-val {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}

  </style>
  <!-- Plotly.js via CDN -->
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
</head>
<body>

<!-- ── Floating Table of Contents ───────────────────────────── -->
<nav class="toc" id="toc">
  <button class="toc-toggle-btn" id="toc-toggle" title="Toggle table of contents" aria-label="Toggle table of contents">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="15" y2="12"/>
      <line x1="3" y1="18" x2="18" y2="18"/>
    </svg>
  </button>
  <div class="toc-panel" id="toc-panel" role="navigation" aria-label="Page contents">
    <div class="toc-heading" data-i18n="toc.title">Contents</div>
    <ul class="toc-list">
      <li>
        <a href="#section-overview" class="toc-link" data-section="section-overview">
          <span class="toc-dot"></span><span data-i18n="nav.overview">Overview</span>
        </a>
      </li>
      <li>
        <a href="#section-latency" class="toc-link" data-section="section-latency">
          <span class="toc-dot"></span><span data-i18n="nav.latency">Latency Analysis</span>
        </a>
      </li>
      <li>
        <a href="#section-throughput" class="toc-link" data-section="section-throughput">
          <span class="toc-dot"></span><span data-i18n="nav.throughput">Throughput Analysis</span>
        </a>
      </li>
      <li>
        <a href="#section-runs" class="toc-link" data-section="section-runs">
          <span class="toc-dot"></span><span data-i18n="nav.runs">Per-Run Details</span>
        </a>
        {% if run_sections %}
        <ul class="toc-sub">
          {% for run in run_sections %}
          <li>
            <a href="#run-{{ loop.index }}" class="toc-link toc-sub-link"
               data-section="run-{{ loop.index }}" title="{{ run.name }}">
              <span class="toc-dot"></span>{{ run.name }}
            </a>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </li>
    </ul>
  </div>
</nav>

<!-- ── Back to top ──────────────────────────────────────────── -->
<a href="#top" class="back-to-top" id="back-to-top" aria-label="Back to top">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
    <polyline points="18 15 12 9 6 15"/>
  </svg>
</a>

<div class="container" id="top">

  <!-- ── Header ─────────────────────────────────────────────── -->
  <header class="report-header">
    <div class="header-inner">
      <div class="header-eyebrow">
        <span class="header-badge">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          <a href="https://github.com/modelscope/evalscope" target="_blank" rel="noopener">EvalScope v{{ evalscope_version }}</a>
        </span>
        <!-- Language toggle: EN / 中文 -->
        <div class="lang-switcher" role="group" aria-label="Language selection">
          <button class="lang-btn active" data-lang="en">EN</button>
          <button class="lang-btn" data-lang="zh">中文</button>
        </div>
      </div>
      <h1 class="report-title" data-i18n="header.title">Performance Benchmark Report</h1>
      <div class="meta-chips">
        <div class="meta-chip">
          <span class="meta-chip-label" data-i18n="meta.model">Model</span>
          <span class="meta-chip-value" title="{{ model }}">{{ model }}</span>
        </div>
        <div class="meta-chip">
          <span class="meta-chip-label" data-i18n="meta.api_type">API Type</span>
          <span class="meta-chip-value">{{ api_type }}</span>
        </div>
        <div class="meta-chip">
          <span class="meta-chip-label" data-i18n="meta.dataset">Dataset</span>
          <span class="meta-chip-value">{{ dataset }}</span>
        </div>
        <div class="meta-chip">
          <span class="meta-chip-label" data-i18n="meta.generated_at">Generated at</span>
          <span class="meta-chip-value">{{ generated_at }}</span>
        </div>
      </div>
    </div>
  </header>

  <!-- ── Overview ───────────────────────────────────────────── -->
  <section class="section" id="section-overview">
    <div class="section-header">
      <div class="section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
        </svg>
      </div>
      <h2 class="section-title" data-i18n="section.overview">Overview</h2>
    </div>

    {% if basic_info %}
    <div class="card">
      <div class="card-header">
        <span class="card-title" data-i18n="card.basic_info">Basic Information</span>
      </div>
      <div class="table-wrap">
        <table>
          <tbody>
            {% for key, value in basic_info.items() %}
            <tr>
              <td style="font-weight:600; color:var(--accent); width:35%;">{{ key }}</td>
              <td>{{ value }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endif %}

    {% if summary_rows %}
    <div class="card">
      <div class="card-header">
        <span class="card-title" data-i18n="card.perf_metrics">Detailed Performance Metrics</span>
        <span class="card-badge">{{ summary_rows | length }} <span data-i18n="badge.runs">runs</span></span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>{% for col in summary_columns %}<th>{{ col }}</th>{% endfor %}</tr>
          </thead>
          <tbody>
            {% for row in summary_rows %}
            <tr>{% for val in row %}<td class="num-cell">{{ val }}</td>{% endfor %}</tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endif %}

    {% if best_config %}
    <div class="card">
      <div class="card-header">
        <span class="card-title" data-i18n="card.best_config">Best Performance Configuration</span>
      </div>
      <div class="table-wrap">
        <table>
          <tbody>
            {% for key, value in best_config.items() %}
            <tr>
              <td style="font-weight:600; color:var(--accent); width:35%;">{{ key }}</td>
              <td style="color:var(--green);">{{ value }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endif %}

    {% if recommendations %}
    <div class="card">
      <div class="card-header">
        <span class="card-title" data-i18n="card.recommendations">Performance Recommendations</span>
      </div>
      <div style="padding:1rem 1.25rem;">
        {% for rec in recommendations %}
        <div style="display:flex; align-items:flex-start; gap:0.5rem; margin-bottom:0.5rem; color:var(--yellow); font-size:0.875rem;">
          <span style="flex-shrink:0;">&#8226;</span>
          <span>{{ rec }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </section>

  <!-- ── Latency Analysis ───────────────────────────────────── -->
  <section class="section" id="section-latency">
    <div class="section-header">
      <div class="section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h2 class="section-title" data-i18n="section.latency">Latency Analysis</h2>
    </div>

    {% if latency_tabs %}
    <div class="card">
      <div class="tab-group" data-tabgroup="latency">
        <div class="tab-nav">
          {% for tab in latency_tabs %}
          <button class="tab-btn {% if loop.first %}active{% endif %}"
                  data-tab="latency-tab-{{ loop.index0 }}"
                  data-i18n="{{ tab.label }}">{{ tab.label }}</button>
          {% endfor %}
        </div>
        {% for tab in latency_tabs %}
        <div class="tab-pane {% if loop.first %}active{% endif %}"
             id="latency-tab-{{ loop.index0 }}">
          <div class="chart-wrap">{{ tab.chart | safe }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </section>

  <!-- ── Throughput Analysis ────────────────────────────────── -->
  <section class="section" id="section-throughput">
    <div class="section-header">
      <div class="section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
      </div>
      <h2 class="section-title" data-i18n="section.throughput">Throughput Analysis</h2>
    </div>

    {% if throughput_tabs %}
    <div class="card">
      <div class="tab-group" data-tabgroup="throughput">
        <div class="tab-nav">
          {% for tab in throughput_tabs %}
          <button class="tab-btn {% if loop.first %}active{% endif %}"
                  data-tab="throughput-tab-{{ loop.index0 }}"
                  data-i18n="{{ tab.label }}">{{ tab.label }}</button>
          {% endfor %}
        </div>
        {% for tab in throughput_tabs %}
        <div class="tab-pane {% if loop.first %}active{% endif %}"
             id="throughput-tab-{{ loop.index0 }}">
          <div class="chart-wrap">{{ tab.chart | safe }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </section>

  <!-- ── Per-Run Details ────────────────────────────────────── -->
  <section class="section" id="section-runs">
    <div class="section-header">
      <div class="section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11l3 3L22 4"/>
          <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
        </svg>
      </div>
      <h2 class="section-title" data-i18n="section.runs">Per-Run Details</h2>
    </div>

    {% for run in run_sections %}
    <details class="ds-card" id="run-{{ loop.index }}" {% if loop.first %}open{% endif %}>
      <summary class="ds-summary">
        <div class="ds-summary-left">
          <span class="ds-arrow">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </span>
          <span class="ds-name">{{ run.name }}</span>
        </div>
        <div class="ds-summary-right">
          <span class="card-badge">{{ run.total_requests }} <span data-i18n="badge.requests">requests</span></span>
        </div>
      </summary>

      <div class="ds-body">

        <!-- Run Summary (benchmark_summary.json) -->
        {% if run.summary_items %}
        <div class="sub-card" style="margin-bottom:1rem;">
          <div class="sub-card-header" data-i18n="card.run_summary">Run Summary</div>
          <div class="stat-grid">
            {% for item in run.summary_items %}
            <div class="stat-item">
              <span class="stat-key">{{ item.key }}</span>
              <span class="stat-val">{{ item.value }}</span>
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        <!-- Percentile Table -->
        {% if run.percentile_rows %}
        <div class="card" style="margin-bottom:1rem;">
          <div class="card-header">
            <span class="card-title" data-i18n="card.percentile_dist">Percentile Distribution</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>{% for col in run.percentile_columns %}<th>{{ col }}</th>{% endfor %}</tr>
              </thead>
              <tbody>
                {% for row in run.percentile_rows %}
                <tr>{% for val in row %}<td class="num-cell">{{ val }}</td>{% endfor %}</tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
        {% endif %}

        <!-- Percentile Curves -->
        {% if run.percentile_chart %}
        <div class="sub-card">
          <div class="sub-card-header" data-i18n="card.percentile_curves">Percentile Curves</div>
          <div class="chart-wrap">{{ run.percentile_chart | safe }}</div>
        </div>
        {% endif %}

        <!-- Per-Request Detail Charts -->
        {% if run.request_detail_tabs %}
        {% set run_idx = loop.index %}
        <div class="sub-card" style="margin-top:1rem;">
          <div class="sub-card-header" data-i18n="card.per_request">Per-Request Details</div>
          <div class="tab-group" data-tabgroup="req-{{ run_idx }}">
            <div class="tab-nav">
              {% for tab in run.request_detail_tabs %}
              <button class="tab-btn {% if loop.first %}active{% endif %}"
                      data-tab="req-{{ run_idx }}-tab-{{ loop.index0 }}"
                      data-i18n="{{ tab.label }}">{{ tab.label }}</button>
              {% endfor %}
            </div>
            {% for tab in run.request_detail_tabs %}
            <div class="tab-pane {% if loop.first %}active{% endif %}"
                 id="req-{{ run_idx }}-tab-{{ loop.index0 }}">
              <div class="chart-wrap">{{ tab.chart | safe }}</div>
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}

      </div>
    </details>
    {% endfor %}

  </section>

  <!-- ── Footer ─────────────────────────────────────────────── -->
  <footer class="report-footer">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
    </svg>
    <span data-i18n="footer.generated_by">Generated by</span>
    <a href="https://github.com/modelscope/evalscope" target="_blank" rel="noopener">EvalScope v{{ evalscope_version }}</a>
  </footer>

</div><!-- /container -->

<script>
(function () {
  'use strict';

  /* ═══════════════════════════════════════════════════════════════════
   * i18n module
   *
   * All translatable UI strings live in the I18N dictionary below.
   * Keys follow a dot-notation namespace:
   *   toc.*       — floating table of contents
   *   nav.*       — TOC link labels
   *   header.*    — page header text
   *   meta.*      — header meta-chip labels
   *   section.*   — section heading titles
   *   card.*      — card / sub-card heading titles
   *   badge.*     — inline count suffixes ("runs", "requests")
   *   footer.*    — footer text
   *   <tab label> — dynamic tab labels injected by Python/Jinja2
   *
   * To add a new language, duplicate the `en` block, change the key,
   * and provide translated values. No other code changes are required.
   * ═══════════════════════════════════════════════════════════════════ */
  var I18N = {

    en: {
      /* ── Navigation / TOC ─────────────────────── */
      'toc.title':          'Contents',
      'nav.overview':       'Overview',
      'nav.latency':        'Latency Analysis',
      'nav.throughput':     'Throughput Analysis',
      'nav.runs':           'Per-Run Details',

      /* ── Page header ──────────────────────────── */
      'header.title':       'Performance Benchmark Report',
      'meta.model':         'Model',
      'meta.api_type':      'API Type',
      'meta.dataset':       'Dataset',
      'meta.generated_at':  'Generated at',

      /* ── Section headings ─────────────────────── */
      'section.overview':   'Overview',
      'section.latency':    'Latency Analysis',
      'section.throughput': 'Throughput Analysis',
      'section.runs':       'Per-Run Details',

      /* ── Card / sub-card titles ───────────────── */
      'card.basic_info':        'Basic Information',
      'card.perf_metrics':      'Detailed Performance Metrics',
      'card.best_config':       'Best Performance Configuration',
      'card.recommendations':   'Performance Recommendations',
      'card.run_summary':       'Run Summary',
      'card.percentile_dist':   'Percentile Distribution',
      'card.percentile_curves': 'Percentile Curves',
      'card.per_request':       'Per-Request Details',

      /* ── Inline badge suffixes ────────────────── */
      'badge.runs':     'runs',
      'badge.requests': 'requests',

      /* ── Footer ───────────────────────────────── */
      'footer.generated_by': 'Generated by',

      /* ── Tab labels (from Python / Jinja2) ───────
       * Keys must match the `label` field produced by
       * generate_report.py and perf_charts.py exactly.   */
      'Latency':            'Latency',
      'TTFT':               'TTFT',
      'TPOT':               'TPOT',
      'Request Throughput': 'Request Throughput',
      'Token Throughput':   'Token Throughput',
      'Success Rate':       'Success Rate',
      'Tokens':             'Tokens',
      'ITL':                'ITL',
      'Success':            'Success',
    },

    zh: {
      /* ── Navigation / TOC ─────────────────────── */
      'toc.title':          '目录',
      'nav.overview':       '概览',
      'nav.latency':        '延迟分析',
      'nav.throughput':     '吞吐量分析',
      'nav.runs':           '运行详情',

      /* ── Page header ──────────────────────────── */
      'header.title':       '性能基准测试报告',
      'meta.model':         '模型',
      'meta.api_type':      'API 类型',
      'meta.dataset':       '数据集',
      'meta.generated_at':  '生成时间',

      /* ── Section headings ─────────────────────── */
      'section.overview':   '概览',
      'section.latency':    '延迟分析',
      'section.throughput': '吞吐量分析',
      'section.runs':       '运行详情',

      /* ── Card / sub-card titles ───────────────── */
      'card.basic_info':        '基本信息',
      'card.perf_metrics':      '详细性能指标',
      'card.best_config':       '最佳性能配置',
      'card.recommendations':   '性能建议',
      'card.run_summary':       '运行摘要',
      'card.percentile_dist':   '百分位分布',
      'card.percentile_curves': '百分位曲线',
      'card.per_request':       '每请求详情',

      /* ── Inline badge suffixes ────────────────── */
      'badge.runs':     '轮',
      'badge.requests': '个请求',

      /* ── Footer ───────────────────────────────── */
      'footer.generated_by': '由以下工具生成',

      /* ── Tab labels (from Python / Jinja2) ───────
       * Keys must match the `label` field produced by
       * generate_report.py and perf_charts.py exactly.   */
      'Latency':            '延迟',
      'TTFT':               '首 Token 时间',
      'TPOT':               '每 Token 时间',
      'Request Throughput': '请求吞吐量',
      'Token Throughput':   'Token 吞吐量',
      'Success Rate':       '成功率',
      'Tokens':             'Token 数',
      'ITL':                'Token 间延迟',
      'Success':            '请求成功率',
    },

  }; /* end I18N */

  /* ── Language switcher ─────────────────────────────────────────── */

  /**
   * Apply a language to the page.
   *
   * Walks every element carrying a [data-i18n] attribute and replaces
   * its text content with the matching translation. Falls back silently
   * when a key is absent (element keeps its original text).
   *
   * @param {string} lang - Language code: 'en' | 'zh'
   */
  function setLang(lang) {
    if (!I18N[lang]) return;
    var dict = I18N[lang];

    /* Update all translated elements */
    document.querySelectorAll('[data-i18n]').forEach(function (el) {
      var key = el.dataset.i18n;
      if (Object.prototype.hasOwnProperty.call(dict, key)) {
        el.textContent = dict[key];
      }
    });

    /* Highlight the active lang button */
    document.querySelectorAll('.lang-btn').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });

    /* Update <html lang> for accessibility / SEO */
    document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';

    /* Persist selection across page reloads */
    try { localStorage.setItem('evalscope-lang', lang); } catch (e) { /* ignore */ }
  }

  /* Bind click handlers to the EN / 中文 toggle buttons */
  document.querySelectorAll('.lang-btn').forEach(function (btn) {
    btn.addEventListener('click', function () { setLang(btn.dataset.lang); });
  });

  /* Restore the last-selected language on page load */
  (function initLang() {
    try {
      var saved = localStorage.getItem('evalscope-lang');
      if (saved && I18N[saved]) { setLang(saved); }
    } catch (e) { /* ignore */ }
  }());

  /* ── Tab switching ─────────────────────────────────────────────── */
  document.querySelectorAll('.tab-group').forEach(function (group) {
    group.querySelectorAll('.tab-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.dataset.tab;

        /* Update button active state */
        group.querySelectorAll('.tab-btn').forEach(function (b) {
          b.classList.toggle('active', b === btn);
        });

        /* Show target pane; trigger Plotly resize when newly visible */
        group.querySelectorAll('.tab-pane').forEach(function (pane) {
          var wasHidden = !pane.classList.contains('active');
          pane.classList.toggle('active', pane.id === target);
          if (wasHidden && pane.classList.contains('active')) {
            window.dispatchEvent(new Event('resize'));
          }
        });
      });
    });
  });

  /* ── Per-run accordion arrow + Plotly resize on open ──────────── */
  document.querySelectorAll('details.ds-card').forEach(function (el) {
    var arrow = el.querySelector('.ds-arrow');
    function syncArrow() {
      if (arrow) arrow.style.transform = el.open ? 'rotate(90deg)' : 'rotate(0deg)';
    }
    syncArrow();
    el.addEventListener('toggle', function () {
      syncArrow();
      if (el.open) window.dispatchEvent(new Event('resize'));
    });
  });

  /* ── Floating TOC toggle ───────────────────────────────────────── */
  var toc       = document.getElementById('toc');
  var tocToggle = document.getElementById('toc-toggle');

  if (window.innerWidth >= 1320) toc.classList.add('expanded');

  tocToggle.addEventListener('click', function () {
    toc.classList.toggle('expanded');
  });

  document.addEventListener('click', function (e) {
    if (!toc.contains(e.target)) toc.classList.remove('expanded');
  });

  /* ── TOC smooth scroll + mobile close ─────────────────────────── */
  document.querySelectorAll('.toc-link').forEach(function (link) {
    link.addEventListener('click', function (e) {
      var href = link.getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      e.preventDefault();
      var target = document.getElementById(href.slice(1));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        if (window.innerWidth < 1320) toc.classList.remove('expanded');
      }
    });
  });

  /* ── TOC active section via IntersectionObserver ──────────────── */
  var tocSections = [];
  document.querySelectorAll('.toc-link[data-section]').forEach(function (link) {
    var id = link.dataset.section;
    var el = document.getElementById(id);
    if (el) tocSections.push({ id: id, el: el, link: link });
  });

  var currentActive = null;
  function setActive(id) {
    if (currentActive === id) return;
    currentActive = id;
    tocSections.forEach(function (s) {
      s.link.classList.toggle('active', s.id === id);
    });
  }

  if ('IntersectionObserver' in window && tocSections.length) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    }, { rootMargin: '-15% 0px -70% 0px', threshold: 0 });
    tocSections.forEach(function (s) { obs.observe(s.el); });
  }

  /* ── Back-to-top visibility ────────────────────────────────────── */
  var btt = document.getElementById('back-to-top');
  if (btt) {
    window.addEventListener('scroll', function () {
      btt.classList.toggle('visible', window.scrollY > 300);
    }, { passive: true });
    btt.addEventListener('click', function (e) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

}());
</script>

</body>
</html>
