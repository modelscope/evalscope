# Pre-built image for Claude Code agent evaluation.
#
# Build:
#   docker build -f evalscope/agent/external/dockerfiles/Dockerfile.claude-code \
#                -t evalscope-claude-code:latest .
#
# Usage:
#   When running EvalScope with framework='claude-code' and pointing the
#   environment at this image, ``setup()`` detects the pre-installed
#   ``claude`` binary and skips the npm install step entirely.
#
# If you do NOT use this image, the runner's ``auto_install=True``
# (default) will install Node.js + @anthropic-ai/claude-code at runtime
# — functional but adds ~30-60s on first invocation.

FROM node:20-slim

# Use Chinese mirrors for faster builds in mainland China.
# apt: Aliyun Debian mirror; npm: npmmirror.
RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || \
    sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list 2>/dev/null || true
RUN npm config set registry https://registry.npmmirror.com

# System utilities required by claude-code at runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install @anthropic-ai/claude-code globally.
RUN npm install -g --no-fund --no-audit @anthropic-ai/claude-code && \
    claude --version

# Default working directory for the agent.
WORKDIR /workspace
